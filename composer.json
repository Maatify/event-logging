{
  "name": "maatify/event-logging",
  "description": "Framework-agnostic standalone event logging library containing isolated Maatify logging domains. Depends only on explicit Composer/runtime dependencies.",
  "keywords": [
    "audit",
    "audit-trail",
    "behavior-trace",
    "delivery-operations",
    "diagnostics-telemetry",
    "event-logging",
    "logging",
    "maatify",
    "mysql",
    "pdo",
    "php",
    "security-signals"
  ],
  "homepage": "https://github.com/Maatify/event-logging",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Maatify",
      "email": "support@maatify.com",
      "homepage": "https://maatify.dev"
    }
  ],
  "support": {
    "issues": "https://github.com/Maatify/event-logging/issues",
    "source": "https://github.com/Maatify/event-logging"
  },
  "autoload": {
    "psr-4": {
      "Maatify\\EventLogging\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Maatify\\EventLogging\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "ext-pdo": "*",
    "maatify/exceptions": "^1.1",
    "maatify/persistence": "^1.1.0",
    "maatify/shared-common": "^1.0",
    "psr/log": "^3.0",
    "ramsey/uuid": "^4.9"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.2",
    "phpunit/phpunit": "^10.0 || ^11.0"
  },
  "suggest": {
    "php-di/php-di": "Optional DI container integration for wiring maatify/event-logging bindings."
  },
  "scripts": {
    "analyse": "phpstan analyse src tests --level=max",
    "test": "phpunit",
    "test:unit": "phpunit --testsuite Unit",
    "test:regression": "phpunit --testsuite Regression",
    "test:integration": "phpunit --testsuite Integration"
  },
  "config": {
    "optimize-autoloader": true,
    "platform": {
      "php": "8.2.0"
    },
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
