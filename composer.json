{
  "name": "maatify/event-logging",
  "description": "Standalone event logging library containing isolated Maatify logging domains.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "ext-pdo": "*",
    "psr/log": "^3.0",
    "ramsey/uuid": "^4.9",
    "maatify/exceptions": "^1.1",
    "maatify/shared-common": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Maatify\\EventLogging\\": "src/"
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^2.2",
    "phpunit/phpunit": "^10.0 || ^11.0"
  },
  "autoload-dev": {
    "psr-4": {
      "Maatify\\EventLogging\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite Unit",
    "test:integration": "phpunit --testsuite Integration"
  }
}
