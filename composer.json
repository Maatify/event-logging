{
  "name": "maatify/event-logging",
  "description": "Standalone event logging library containing isolated Maatify logging domains.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "ext-pdo": "*",
    "psr/log": "^3.0",
    "ramsey/uuid": "^4.9"
  },
  "autoload": {
    "psr-4": {
      "Maatify\\EventLogging\\": "src/"
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^2.2",
    "phpstan/phpstan-strict-rules": "^2.0"
  }
}
